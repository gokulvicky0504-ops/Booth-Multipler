module tb_booth();

reg signed [7:0] A, B;
wire signed [15:0] P;

multiplier_booth uut (
    .A(A),
    .B(B),
    .P(P)
);

initial begin
    A = 8'd12;  B = 8'd5;
    #10;
    $display("%d * %d = %d", A, B, P);

    A = -8'd7;  B = 8'd3;
    #10;
    $display("%d * %d = %d", A, B, P);

    A = -8'd8;  B = -8'd4;
    #10;
    $display("%d * %d = %d", A, B, P);

    $finish;
end
